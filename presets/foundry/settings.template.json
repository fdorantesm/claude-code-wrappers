{
  "env": {
    "CLAUDE_CODE_USE_FOUNDRY": "1",
    "ANTHROPIC_FOUNDRY_BASE_URL": "${FOUNDRY_BASE_URL}",
    "ANTHROPIC_FOUNDRY_API_KEY": "${FOUNDRY_API_KEY}",
    "ANTHROPIC_MODEL": "${FOUNDRY_DEFAULT_MODEL:-claude-opus-4-8}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${FOUNDRY_OPUS_MODEL:-claude-opus-4-8}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${FOUNDRY_SONNET_MODEL:-claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${FOUNDRY_HAIKU_MODEL:-claude-haiku-4-5}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-600000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
  },
  "model": "sonnet",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
