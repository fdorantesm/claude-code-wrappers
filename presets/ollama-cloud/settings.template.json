{
  "env": {
    "ANTHROPIC_BASE_URL": "${OLLAMA_CLOUD_BASE_URL:-http://localhost:11434}",
    "ANTHROPIC_AUTH_TOKEN": "${OLLAMA_CLOUD_AUTH_TOKEN:-ollama-cloud-local}",
    "ANTHROPIC_MODEL": "${OLLAMA_CLOUD_MODEL:-gpt-oss:120b-cloud}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${OLLAMA_CLOUD_OPUS_MODEL:-gpt-oss:120b-cloud}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${OLLAMA_CLOUD_SONNET_MODEL:-gpt-oss:120b-cloud}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${OLLAMA_CLOUD_HAIKU_MODEL:-qwen3:8b-cloud}",
    "ANTHROPIC_SMALL_FAST_MODEL": "${OLLAMA_CLOUD_SMALL_FAST_MODEL:-qwen3:8b-cloud}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-300000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}",
    "DISABLE_PROMPT_CACHING": "${DISABLE_PROMPT_CACHING:-1}"
  },
  "model": "sonnet",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
