{
  "env": {
    "ANTHROPIC_BASE_URL": "${OPENROUTER_BASE_URL:-https://openrouter.ai/api/v1}",
    "ANTHROPIC_AUTH_TOKEN": "${OPENROUTER_API_KEY}",
    "ANTHROPIC_MODEL": "${OPENROUTER_DEFAULT_MODEL:-anthropic/claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${OPENROUTER_OPUS_MODEL:-anthropic/claude-opus-4-8}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${OPENROUTER_SONNET_MODEL:-anthropic/claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${OPENROUTER_HAIKU_MODEL:-anthropic/claude-haiku-4-5}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-600000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
  },
  "model": "sonnet",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
