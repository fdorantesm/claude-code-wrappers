{
  "awsAuthRefresh": "${AWS_AUTH_REFRESH_CMD:-aws sso login --profile ${AWS_PROFILE}}",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "${AWS_PROFILE:-default}",
    "AWS_REGION": "${AWS_REGION:-us-east-1}",
    "AWS_DEFAULT_REGION": "${AWS_REGION:-us-east-1}",
    "AWS_SDK_LOAD_CONFIG": "1",
    "ANTHROPIC_MODEL": "${BEDROCK_SONNET_MODEL_ARN}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${BEDROCK_SONNET_MODEL_ARN}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${BEDROCK_SONNET_MODEL_ARN}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${BEDROCK_HAIKU_MODEL_ARN}",
    "ANTHROPIC_SMALL_FAST_MODEL": "${BEDROCK_HAIKU_MODEL_ARN}",
    "ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION": "${AWS_REGION:-us-east-1}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-600000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
  },
  "model": "haiku",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
