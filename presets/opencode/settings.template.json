{
  "env": {
    "ANTHROPIC_BASE_URL": "${OPENCODE_BASE_URL:-https://opencode.ai/zen/v1}",
    "ANTHROPIC_AUTH_TOKEN": "${OPENCODE_TOKEN}",
    "ANTHROPIC_MODEL": "${OPENCODE_DEFAULT_MODEL:-claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${OPENCODE_OPUS_MODEL:-claude-opus-4-8}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${OPENCODE_SONNET_MODEL:-claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${OPENCODE_HAIKU_MODEL:-claude-haiku-4-5}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-600000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
  },
  "model": "sonnet",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
