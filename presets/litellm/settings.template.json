{
  "env": {
    "ANTHROPIC_BASE_URL": "${LITELLM_BASE_URL:-http://localhost:4000}",
    "ANTHROPIC_AUTH_TOKEN": "${LITELLM_API_KEY:-sk-local}",
    "ANTHROPIC_MODEL": "${LITELLM_DEFAULT_MODEL:-claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${LITELLM_OPUS_MODEL:-claude-opus-4-8}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${LITELLM_SONNET_MODEL:-claude-sonnet-4-6}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${LITELLM_HAIKU_MODEL:-claude-haiku-4-5}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-600000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"
  },
  "model": "sonnet",
  "theme": "${CLAUDE_THEME:-dark-daltonized}"
}
