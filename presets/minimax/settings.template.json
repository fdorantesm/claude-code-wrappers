    "ANTHROPIC_BASE_URL": "${MINIMAX_BASE_URL}",
    "ANTHROPIC_AUTH_TOKEN": "${MINIMAX_TOKEN}",
    "ANTHROPIC_MODEL": "${MINIMAX_DEFAULT_MODEL}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${MINIMAX_OPUS_MODEL}",
