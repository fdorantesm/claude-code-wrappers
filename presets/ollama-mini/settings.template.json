{
  "env": {
    "ANTHROPIC_BASE_URL": "${OLLAMA_MINI_BASE_URL:-http://mini.lan:11434}",
    "ANTHROPIC_AUTH_TOKEN": "${OLLAMA_MINI_AUTH_TOKEN:-ollama-mini-local}",
    "ANTHROPIC_MODEL": "${OLLAMA_MINI_MODEL:-gemma3:e2b-it-q4_K_M}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${OLLAMA_MINI_OPUS_MODEL:-gemma3:e2b-it-q4_K_M}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${OLLAMA_MINI_SONNET_MODEL:-gemma3:e2b-it-q4_K_M}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${OLLAMA_MINI_HAIKU_MODEL:-gemma3:1b-it-q4_K_M}",
    "ANTHROPIC_SMALL_FAST_MODEL": "${OLLAMA_MINI_SMALL_FAST_MODEL:-gemma3:1b-it-q4_K_M}",
    "API_TIMEOUT_MS": "${API_TIMEOUT_MS:-300000}",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}",
    "DISABLE_PROMPT_CACHING": "${DISABLE_PROMPT_CACHING:-1}"
